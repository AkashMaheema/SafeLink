rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isPrivilegedUser() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['admin', 'government'];
    }

    // Users can read and write only their own profile document
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isPrivilegedUser());
      allow write: if isSignedIn() && (request.auth.uid == uid || isPrivilegedUser());
    }

    // Alerts: any authenticated user can read and create their own alert;
    // privileged roles can update/delete.
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if isPrivilegedUser();

      // Votes subcollection: any signed-in user can read all votes,
      // but can only write/delete their own vote document (doc id == uid).
      match /votes/{uid} {
        allow read: if isSignedIn();
        allow write, delete: if isSignedIn() && request.auth.uid == uid;
      }

      // Comments subcollection: any signed-in user can read and create;
      // only the comment author can delete their own comment.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid;
        allow delete: if isSignedIn()
          && resource.data.uid == request.auth.uid;
      }

      // Proofs subcollection: any signed-in user can create proof documents
      // (Base64 images stored here instead of Firebase Storage).
      // Privileged users can delete proofs during moderation.
      match /proofs/{proofId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isPrivilegedUser();
      }
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
