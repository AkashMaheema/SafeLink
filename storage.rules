rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Proof files attached to alerts
    // Path: alerts/{alertId}/proof/{type}/{filename}
    match /alerts/{alertId}/proof/{type}/{filename} {
      // Any signed-in user can upload proof (size enforced in app)
      allow write: if request.auth != null;

      // Public read so proof can be displayed in the app
      allow read: if true;
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
